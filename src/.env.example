# Path to the raw IEMOCAP dataset root.
# Expected structure:
# IEMOCAP_full_release/
#   Session1/
#   Session2/
#   ...
IEMOCAP_ROOT_DIR="D:\path\to\IEMOCAP_full_release"

# Output directory for parsed metadata CSV files.
OUTPUT_DIR="D:\path\to\conv-ser\dataset\IEMOCAP_metadata"

# Output directory for clean Wav2Vec2 embedding files.
EMBEDDINGS_DIR="D:\path\to\conv-ser\dataset\IEMOCAP_embeddings"

# Local Wav2Vec2 checkpoint/model directory.
# Should contain files such as:
# - preprocessor_config.json
# - pytorch_model.bin or model.safetensors
# - config.json, if available
WAV2VEC2_MODEL_DIR="D:\path\to\conv-ser\models\wav2vec2_sent"

# Device selection: "auto", "cuda", or "cpu".
# Use "auto" if you want the script to use GPU when available and CPU otherwise.
DEVICE="auto"

# Output directory for the separate noisy/AWGN embedding branch.
NOISY_EMBEDDINGS_DIR="D:\path\to\conv-ser\dataset\IEMOCAP_noisy_embeddings"

# AWGN noise strength for the noisy branch.
# Higher = cleaner, lower = noisier.
# Common values: 20 light noise, 15 medium noise, 10 strong noise.
AWGN_SNR_DB="15"

# Dynamic AWGN settings for training-time augmentation.
# Used by src/data/iemocap_dynamic_awgn_dataset.py.
DYNAMIC_AWGN_PROB="0.5"
DYNAMIC_AWGN_SNR_CHOICES="10,15,20"

# Separate checkpoints for src/training/scr_noise/train_bigru.py.
SCR_NOISE_CHECKPOINT_DIR="D:\path\to\conv-ser\checkpoints\scr_noise_bigru"

# Labels used by --mode flat8 in the scr_noise baseline.
# Override if your experiment defines flat8 differently.
FLAT8_LABELS="ang,sad,hap,exc,neu,fru,fea,sur"
